PROXY_PORT=8080

# Database backend: "postgres" (default) or "sqlite".
#   postgres -> uses the bundled Postgres service via DATABASE_URL (set in
#               docker-compose.yml).
#   sqlite   -> lightweight single-file DB shared by both services via the
#               oi_data volume at SQLITE_PATH (/data/openinspector.db). No
#               Postgres needed; WAL mode handles the proxy+dashboard writers.
# DB_BACKEND=postgres
# SQLITE_PATH=/data/openinspector.db

# # If using open router with OpenAI SKD
# BASE_URL=https://openrouter.ai/api/v1

# If using open router with Claude Code
# BASE_URL=https://openrouter.ai/api

# If using a local ollama instance on the host machine, use:
BASE_URL=http://host.docker.internal:11434

# To Kill long request (Infinte generation loops with local models)
GLOBAL_TIMEOUT = 150

# Per-operation upstream read timeout (seconds). Detects a stalled upstream
# that stops emitting chunks mid-stream. GLOBAL_TIMEOUT still caps total duration.
READ_TIMEOUT = 60

# Retry on Rate Limits
MAX_RETRIES = 3
BASE_DELAY = 3.0

# Number of uvicorn worker processes for the proxy (concurrency under load).
UVICORN_WORKERS = 2
